# 读通鉴 — 环境变量样例
# 复制这份为 .env.local,然后填实际值

# --- 邮件订阅(Resend)---
# 在 https://resend.com 注册,创建 API Key,把 key 填这里
# 没设置时,邮件订阅 API 会返回 503,前端展示"邮件服务暂未配置"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# 发件地址(Resend 域名校验通过后,改成 hello@yourdomain.com)
SUBSCRIBE_FROM_EMAIL=读通鉴 <onboarding@resend.dev>

# HMAC 签名 secret(用来签确认/取消订阅 token)
# 没设置时 fallback 到 RESEND_API_KEY(生产请一定设一个独立的 32 字节随机字符串)
# openssl rand -hex 32
SUBSCRIBE_SECRET=

# --- 订阅者存储(Upstash Redis)---
# 在 https://upstash.com 注册,创建一个 Redis database,选 Global Edge
# 把 REST URL 和 Token 复制过来
# 没设置时,生产环境 API 返回 503,本地开发 fallback 到内存
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=Axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 基础 ---
# 默认从 SITE_URL(lib/site-config.ts)取,只在自定义域名时设
# 注意:跟 SITE_URL 用同一个 env key,API 路由也读这个
# NEXT_PUBLIC_SITE_URL=https://du-tongjian.com

# --- Stripe 支付(单期 9.90 那档)---
# 在 https://dashboard.stripe.com 注册,先开 Test mode
# Developers → API keys → Reveal test key → 拷贝 secret key(以 sk_test_ 开头)
# 没设置时,/unlock 单期按钮 inline 显示「支付暂未配置」
STRIPE_SECRET_KEY=这里填你的_stripe_test_secret_key
