# 读通鉴 — 环境变量样例
# 复制这份为 .env.local,然后填实际值

# --- 邮件订阅(Resend)---
# 在 https://resend.com 注册,创建 API Key,把 key 填这里
# 没设置时,邮件订阅 API 会返回 503,前端展示"邮件服务暂未配置"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# 发件地址(Resend 域名校验通过后,改成 hello@yourdomain.com)
SUBSCRIBE_FROM_EMAIL=读通鉴 <onboarding@resend.dev>

# HMAC 签名 secret(用来签确认/取消订阅 token)
# 没设置时 fallback 到 RESEND_API_KEY(生产请一定设一个独立的 32 字节随机字符串)
# openssl rand -hex 32
SUBSCRIBE_SECRET=

# --- 订阅者存储(Upstash Redis)---
# 在 https://upstash.com 注册,创建一个 Redis database,选 Global Edge
# 把 REST URL 和 Token 复制过来
# 没设置时,生产环境 API 返回 503,本地开发 fallback 到内存
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=Axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 基础 ---
# 默认从 SITE_URL(lib/site-config.ts)取,只在自定义域名时设
# 注意:跟 SITE_URL 用同一个 env key,API 路由也读这个
# NEXT_PUBLIC_SITE_URL=https://du-tongjian.com

# --- Stripe 支付(单期 9.90 那档)---
# 在 https://dashboard.stripe.com 注册,先开 Test mode
# Developers → API keys → Reveal test key → 拷贝 secret key(以 sk_test_ 开头)
# 没设置时,/unlock 单期按钮 inline 显示「支付暂未配置」
STRIPE_SECRET_KEY=这里填你的_stripe_test_secret_key

# --- AI 问典(RAG 聊天)---
# LLM API — OpenAI 兼容(支持 OpenAI / DeepSeek / 智谱 / 通义千问 等)
# 推荐 DeepSeek:中文好 + 便宜(¥1/百万 tokens)
#   https://platform.deepseek.com 注册 → API Keys 拿 key
#   baseURL: https://api.deepseek.com
#   model: deepseek-chat
# 也支持 OpenAI:
#   baseURL: https://api.openai.com/v1
#   model: gpt-4o-mini
# 不配时,/ask 页面显示「AI 问典暂未上线」
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding — 通常跟 LLM 同源
# DeepSeek 当前没有 embedding,用 OpenAI text-embedding-3-small 便宜(¥0.02/百万 tokens)
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Upstash Vector — 向量数据库(跟 Redis 一起在 Upstash 控制台开)
#   https://console.upstash.com → Create Database → 选 "Vector" 类型
#   复制 REST URL 和 Token
# 不配时,/ask 页面显示「AI 问典暂未上线」
UPSTASH_VECTOR_REST_URL=https://xxx-xxx.upstash-vector.io
UPSTASH_VECTOR_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- TCB 腾讯云 CloudBase(音频 + cover 静态资源)---
# 减 Vercel 部署 size 477 MB + 流量便宜 50% + 国内 CDN 加速
# TCB 控制台 → 用户管理 → 访问凭证 → 生成 SecretId + SecretKey
# (用完建议立刻撤销重生成)
TCB_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxx
TCB_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
TCB_BUCKET=636c-cloud1-d9gv1q8ikad5e9721-1442530204
TCB_REGION=ap-shanghai
TCB_DOMAIN=636c-cloud1-d9gv1q8ikad5e9721-1442530204.tcb.qcloud.la

# --- Audio / Cover CDN base URL---
# 走 TCB 时设这个,前端 audio src 会自动用这个 base + slug + .mp3
# 注意:多项目共用同一 TCB bucket 时,路径必须含项目名(避免音频/封面跨项目混)
#   /history-tool/audio/{slug}.mp3
#   /history-tool/cover/{slug}.webp
# 留空 = 用 Vercel 静态资源(/audios/{slug}.mp3)
NEXT_PUBLIC_AUDIO_BASE_URL=https://636c-cloud1-d9gv1q8ikad5e9721-1442530204.tcb.qcloud.la/history-tool/audio
NEXT_PUBLIC_COVER_BASE_URL=https://636c-cloud1-d9gv1q8ikad5e9721-1442530204.tcb.qcloud.la/history-tool/cover
